{
  "name": "@apps/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/apps/server/src/index.js",
    "build": "pnpm exec tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:stripe-smoke": "vitest run src/__tests__/payment-connect-gate.test.ts src/__tests__/stripe-payment-flow.test.ts src/__tests__/affiliate-commission-unpaid.test.ts src/__tests__/delivery-dispatch-lifecycle.test.ts src/routes/stripe-webhook.route.test.ts src/routes/checkout.route.test.ts src/routes/checkout-card-blocked.test.ts src/services/checkout.service.cod.test.ts src/webhooks/doordash-webhook-payload.test.ts src/webhooks/doordash-webhook-auth.test.ts src/webhooks/doordash-webhook-audit.test.ts src/webhooks/doordash-webhook.integration.test.ts src/env.schema.doordash.test.ts src/routes/delivery-tracking.route.test.ts",
    "test:river": "vitest run src/routes/river.route.test.ts",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.913.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "11",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@fastify/websocket": "^9.0.0",
    "@packages/db": "workspace:*",
    "@packages/domain": "workspace:*",
    "@packages/realtime": "workspace:*",
    "@packages/schemas": "workspace:*",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "fastify": "^4.29.1",
    "fastify-type-provider-zod": "^1.1.9",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.3.2",
    "stripe": "^19.1.0",
    "@types/ws": "^8.18.1",
    "ws": "^8.18.3",
    "typescript": "^5.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.1",
    "eslint": "^8.57.0",
    "form-data": "^4.0.4",
    "supertest": "^7.0.0",
    "pino-pretty": "^13.1.2",
    "tsx": "^4.19.0",
    "vitest": "^2.1.1"
  }
}