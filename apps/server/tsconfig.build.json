{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "paths": {
      "@packages/db":                    ["./packages/db/dist/db/src"],
      "@packages/db/*":                  ["./packages/db/dist/db/src/*"],
      "@packages/domain":                ["./packages/domain/dist"],
      "@packages/domain/*":              ["./packages/domain/dist/*"],
      "@packages/schemas":               ["./packages/schemas/dist/packages/schemas/src"],
