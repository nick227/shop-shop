      "@packages/schemas-river-dto":     ["./packages/schemas/dist/packages/schemas/src/dtos/river.dto"],
      "@packages/realtime":              ["./packages/realtime/dist"],
      "@packages/realtime/*":            ["./packages/realtime/dist/*"]
