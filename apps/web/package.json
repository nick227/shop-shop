{
  "name": "@apps/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:maps": "tsc -p tsconfig.maps-check.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:validation": "vitest run src/__tests__/validation",
    "test:validation:ui": "vitest src/__tests__/validation --ui",
    "test:validation:coverage": "vitest run src/__tests__/validation --coverage",
    "test:types": "vitest run src/types/__tests__ --config src/types/__tests__/vitest.config.ts",
    "test:types:coverage": "vitest run src/types/__tests__ --config src/types/__tests__/vitest.config.ts --coverage",
    "test:types:ui": "vitest src/types/__tests__ --config src/types/__tests__/vitest.config.ts --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "lint": "eslint src --ext .ts,.tsx",
    "knip": "knip",
    "madge": "madge --circular --extensions ts,tsx src/",
    "depcruise": "dependency-cruiser --config .dependency-cruiser.cjs src",
    "depcruise:graph": "dependency-cruiser --config .dependency-cruiser.cjs --output-type dot src | dot -T svg > dependency-graph.svg",
    "semgrep": "semgrep --config=.semgrep.yml src/",
    "semgrep:ci": "semgrep --config=p/security-audit --config=p/secrets --config=p/typescript src/",
    "type-coverage": "type-coverage --detail --strict",
    "type-coverage:ci": "type-coverage --strict --at-least 95",
    "tsd": "tsd",
    "ts-unused-exports": "ts-unused-exports tsconfig.json",
    "analyze": "npm run typecheck && npm run lint && npm run knip && npm run depcruise && npm run type-coverage:ci",
    "analyze:full": "npm run analyze && npm run madge && npm run ts-unused-exports"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@tanstack/react-query": "^5.56.2",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.26.2",
    "sonner": "^1.7.0",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.1.1",
    "vaul": "^1.0.0",
    "zod": "^3.25.76",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "@vitest/ui": "2.1.9",
    "autoprefixer": "^10.4.20",
    "dependency-cruiser": "^17.1.0",
    "eslint": "^9.9.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^61.0.2",
    "globals": "^15.9.0",
    "jsdom": "^25.0.0",
    "knip": "^5.38.2",
    "madge": "^8.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "ts-unused-exports": "^11.0.1",
    "tsd": "^0.33.0",
    "type-coverage": "^2.29.7",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.8",
    "vitest": "^2.1.1"
  }
}