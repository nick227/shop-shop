{
  
  "compilerOptions": {
    "outDir": "dist",
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2021"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "baseUrl": ".",
    "strict": true,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,
    "noImplicitOverride": false,
    "useUnknownInCatchVariables": false,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": false,
    "paths": {
      "@/*": ["./src/*"],
      "@shared": ["./src/shared"],
      "@shared/*": ["./src/shared/*"],
      "@features/*": ["./src/features/*"],
      "@layouts": ["./src/layouts"],
      "@layouts/*": ["./src/layouts/*"],
      "@pages/*": ["./src/pages/*"],
      "@api": ["./src/api"],
      "@api/*": ["./src/api/*"],
      "@stores": ["./src/stores"],
      "@stores/*": ["./src/stores/*"],
      "@services": ["./src/services"],
      "@services/*": ["./src/services/*"],
      "@components": ["./src/components"],
      "@components/*": ["./src/components/*"],
      "@packages/schemas": ["../../packages/schemas/src"],
      "@packages/realtime": ["../../packages/realtime/src"],
      "@packages/shared": ["../../packages/shared/src"],
      "@packages/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "**/*.refactored.ts",
    "**/*.refactored.tsx",
    "src/pages/admin/PayoutAuditLogs.page.tsx",
    "src/pages/admin/PayoutManagement.page.tsx",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx"
  ]
}
