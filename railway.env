# Railway Environment Variables Configuration
# Copy these variables to your respective Railway services

# ==========================================
# WEB SERVICE (shop-shop)
# ==========================================
# API Configuration (browser-facing)
VITE_API_URL=https://shop-shop-server.up.railway.app
VITE_WS_URL=wss://shop-shop-server.up.railway.app/realtime
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
VITE_ENABLE_COD_PAYMENTS=false

# ==========================================
# SERVER SERVICE (shop-shop-server)
# ==========================================
# App Configuration
NODE_ENV=production
PORT=3005
APP_URL=https://shop-shop-server.up.railway.app
CORS_ORIGINS=https://shop-shop.up.railway.app
ENABLE_COD_PAYMENTS=false

# Database (use Railway's MySQL service)
DATABASE_URL=${{MySQL.DATABASE_URL}}

# JWT Secrets (generate new ones for production)
JWT_SECRET=your_real_32_plus_char_secret
JWT_REFRESH_SECRET=your_real_32_plus_char_refresh_secret
JWT_EXPIRES_IN=7d

# Stripe (production keys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Connect (return URLs should point to web app, not API)
STRIPE_CONNECT_RETURN_URL=https://shop-shop.up.railway.app/vendor/connect/success
STRIPE_CONNECT_REFRESH_URL=https://shop-shop.up.railway.app/vendor/connect/refresh

# Storage (Note: Railway local storage may not be durable across deploys)
STORAGE_TYPE=local
UPLOAD_DIR=/app/uploads

# Geocoding (optional)
GEOCODING_API_KEY=your_real_geocoding_key

# DoorDash (basic auth mode - remove HMAC vars for basic mode)
DOORDASH_WEBHOOK_AUTH_MODE=basic
DOORDASH_WEBHOOK_BASIC_USER=shopshop
DOORDASH_WEBHOOK_BASIC_PASSWORD=your_real_strong_password

# ==========================================
# RIVER SERVICE (internal worker)
# ==========================================
# Use private internal URL for server-to-server communication
INTERNAL_API_URL=http://shop-shop-server.railway.internal:3005/api
DATABASE_URL=${{MySQL.DATABASE_URL}}

# ==========================================
# MYSQL SERVICE (Railway-managed)
# ==========================================
# Railway automatically provides these:
# MYSQLUSER=root
# MYSQLPASSWORD=your_password
# MYSQLDATABASE=railway
# MYSQLURL=mysql://root:password@mysql.railway.internal:3306/railway
# MYSQL_PUBLIC_URL=mysql://root:password@trolley.proxy.rlwy.net:11742/railway
# MYSQLPORT=3306

# ==========================================
# ENVIRONMENT-SPECIFIC NOTES
# ==========================================
# 
# For local development, use your local .env file with:
# DATABASE_URL=mysql://user:password@localhost:3306/delivery_app
# PORT=3005
# APP_URL=http://localhost:3005
# CORS_ORIGINS=http://localhost:5177
# VITE_API_URL=http://localhost:3005
# VITE_WS_URL=ws://localhost:3005/realtime
#
# For Railway deployment:
# 1. Copy server service vars to shop-shop-server service
# 2. Copy web service vars to shop-shop service  
# 3. Copy river service vars to river service
# 4. MySQL vars are automatically provided by Railway MySQL service
#
# Private networking pattern: <service-name>.railway.internal:port
# Public URLs: https://<service-name>-<environment>.up.railway.app
