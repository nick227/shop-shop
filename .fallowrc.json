{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "workspaces": {
    "packages": ["apps/*", "packages/*"]
  },
  "ignorePatterns": [
    "**/dist/**",
    "**/node_modules/**",
    "**/__generated__/**",
    "**/coverage/**",
    "packages/schemas/src/**/*.dto.js",
    "packages/schemas/src/index.js",
    "packages/schemas/src/dtos/index.js",
    "packages/schemas/src/core/index.js",
    "packages/schemas/src/core/types.js",
    "packages/schemas/src/core/dto.generator.js",
    "packages/schemas/src/core/openapi.loader.js",
    "packages/schemas/src/core/resource.factory.js"
  ],
  "health": {
    "ignore": [
      "dist",
      "__generated__",
      "coverage",
      "node_modules",
      "**/*.test.ts",
      "**/*.test.tsx",
      "**/*.spec.ts",
      "**/*.spec.tsx",
      "**/e2e/**",
      "**/scripts/**",
      "**/*.cjs",
      "**/prisma/seed*.ts",
      "**/generated/**"
    ]
  },
  "duplicates": {
    "ignore": [
      "dist",
      "__generated__",
      "**/dist/**",
      "**/node_modules/**",
      "**/__generated__/**",
      "**/coverage/**"
    ]
  },
  "rules": {}
}
