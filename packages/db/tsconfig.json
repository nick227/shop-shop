{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "skipLibCheck": true,
    "composite": false
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__/**",
    "src/**/*.test.ts",
    "src/scripts/**",
    "src/generated/zod/index.ts",
    "src/**/*.fixed.ts",
    "src/services/affiliate-payout-hardening.service.ts",
    "src/services/river-content-generation.service.ts",
    "src/services/river-ingest-enhanced.service.ts",
    "src/services/river-scoring.service.ts",
    "src/cli/river-initial-generation.ts"
  ]
}
