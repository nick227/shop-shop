generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}



datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  VENDOR_PENDING
  VENDOR
  ADMIN
  AFFILIATE
  RIDER
  STAFF
}

enum AffiliateStatus {
  PENDING
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  REVERSED
}

enum AffiliateAttributionSource {
  CUSTOMER_REFERRAL
  STORE_REFERRAL
  CHECKOUT_CODE
  REFERRAL_LINK
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AffiliatePayoutProvider {
  MANUAL
  STRIPE_CONNECT
  PAYPAL
  ACH_PROVIDER
}

enum AffiliateProviderStatus {
  NOT_SET
  PENDING
  ACTIVE
  SUSPENDED
  FAILED
}

enum AffiliateRateSource {
  PAYOUT_GROUP
  USER_OVERRIDE
  PLATFORM_DEFAULT
}

enum CommissionSourceType {
  CUSTOMER_PURCHASE
  STORE_REVENUE
  MANUAL
}

enum ReferralEventType {
  STORE_SIGNUP
  USER_SIGNUP
}

enum MediaKind {
  IMAGE
  VIDEO
}

enum CartStatus {
  ACTIVE
  SUBMITTED
  ABANDONED
}

enum OrderStatus {
  PENDING_PAYMENT // awaiting Stripe payment confirmation
  PLACED
  ACCEPTED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED // legacy terminal state
  CANCELED
}

enum DeliveryType {
  DELIVERY
  PICKUP
}

enum DeliveryMode {
  PICKUP
  STORE_MANAGED_DELIVERY
  PLATFORM_DRIVER
  THIRD_PARTY_PROVIDER
}

enum DeliveryProvider {
  IN_HOUSE
  DOORDASH_DRIVE
  UBER_DIRECT
}

enum DeliveryJobStatus {
  REQUESTED
  DISPATCHED
  CANCELED
  FAILED
  COMPLETED
}

enum PaymentProvider {
  TEST
  STRIPE
  SQUARE
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum StoreStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum StoreType {
  RESTAURANT
  CONVENIENCE
  GROCERY
  HOME_KITCHEN
  BAKERY
  RETAIL
  OTHER
  MEAL_PREP
  COFFEE
  SPECIALTY
  GENERAL
}

enum PriceRange {
  BUDGET
  MODERATE
  PREMIUM
}

enum TagCategory {
  DIETARY
  FREE_FROM
  CONTAINS_ALLERGEN
  CUISINE
  FEATURE
  MEAL_TIME
  ITEM_TYPE
  OCCASION
}

enum TagTarget {
  STORE
  ITEM
  BOTH
}

enum TipStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PayoutAdjustmentType {
  CREDIT
  DEBIT
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_ITEM
  FREE_DELIVERY
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
}

/// Origin of a River post (manual vs automation)
enum PostSource {
  MANUAL
  AUTO_STORE
  AUTO_PRODUCT
}

model User {
  id                   String                @id @default(uuid())
  role                 Role                  @default(USER)
  email                String                @unique
  passwordHash         String
  name                 String?
  phone                String?
  isCompany            Boolean               @default(false)
  companyName          String?
  addresses            Address[]
  carts                Cart[]
  orders               Order[]
  storesOwned          Store[]               @relation("StoreOwner")
  paymentMethods       PaymentMethod[]
  promotionsCreated    Promotion[]           @relation("PromotionCreator")
  postLikes            PostLike[]
  comments             Comment[]
  affiliate            Affiliate?
  /// Customer-level affiliate referral attribution (for analytics).
  referredByAffiliateId  String?    @db.Char(36)
  referredByAffiliate    Affiliate? @relation("AffiliateCustomerReferrals", fields: [referredByAffiliateId], references: [id], onDelete: SetNull)
  referredByReferralCode String?
  vendorVerification   VendorVerification?
  teamMemberships      TeamMember[]
  invitationsSent      Invitation[]          @relation("InvitationSender")
  invitationsReceived  Invitation[]          @relation("InvitationRecipient")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  FavoriteStore        FavoriteStore[]
  FavoriteItem         FavoriteItem[]
  assignedOrders       Order[]               @relation("OrderAssignedRider")
  promotionRedemptions PromotionRedemption[]
  vendorPayouts        Payout[]              @relation("VendorPayouts")
  DeliveryJob          DeliveryJob[]
  adminAuditLogs       AdminAuditLog[]       @relation("AdminAuditLogs")
  suspendedAt            DateTime?
  referralAttributedAt   DateTime?

  @@index([referredByAffiliateId])
}

model Store {
  id          String  @id @default(uuid()) @db.Char(36)
  ownerUserId String  @db.Char(36)
  owner       User    @relation("StoreOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  name        String
  slug        String  @unique
  description String?

  // Company Information
  companyName  String?
  taxId        String?
  phone        String?
  email        String?
  website      String?
  customDomain String? @db.VarChar(191)

  // Social Media Links (JSON: { youtube, instagram, facebook, tiktok, twitter, whatsapp, discord, snapchat })
  socialLinksJson Json?

  isPublished      Boolean     @default(false)
  status           StoreStatus @default(ACTIVE)
  storeType        StoreType?
  priceRange       PriceRange?
  disabledAt       DateTime?
  disabledByUserId String?     @db.Char(36)
  disabledReason   String?     @db.Text
  deliveryEnabled  Boolean     @default(true)
  pickupEnabled    Boolean     @default(true)
  prepTimeMin      Int         @default(15)
  feesJson         Json?
  hoursJson        Json?
  timezone         String?      @db.VarChar(50) // IANA timezone identifier (e.g., America/New_York)

  // Branding
  brandColor  String? @db.VarChar(7) // Hex color code #RRGGBB
  accentColor String? @db.VarChar(7) // Hex color code #RRGGBB
  imageUrl   String? @db.VarChar(191) // Store thumbnail/logo

  // Delivery Settings
  deliveryDistance Decimal?       @db.Decimal(5, 2) // Preferred delivery distance in miles
  deliveryCharge   Decimal?       @db.Decimal(10, 2) // Delivery charge amount
  deliveryZones    DeliveryZone[]

  // Geographic Coordinates (for distance-based search)
  latitude  Decimal? @db.Decimal(10, 8) // -90 to 90, 8 decimal precision
  longitude Decimal? @db.Decimal(11, 8) // -180 to 180, 8 decimal precision

  // Structured Address (parsed from addressJson for search)
  addressStreet  String?
  addressCity    String?
  addressState   String? @db.Char(2) // US state abbreviation
  addressZip     String?
  addressCountry String? @default("US") @db.Char(2)

  // Geocoding Metadata
  geocodedAt    DateTime? // When coordinates were last updated
  geocodeSource String? // 'manual' | 'api' | 'import'

  // Affiliate tracking
  referredByAffiliateId String?    @db.Char(36)
  referredByAffiliate   Affiliate? @relation("AffiliateReferrals", fields: [referredByAffiliateId], references: [id], onDelete: SetNull)

  stripeAccountId      String?         @unique @db.VarChar(191)
  stripeOnboarded      Boolean         @default(false)
  stripeChargesEnabled Boolean         @default(false)
  stripePayoutsEnabled Boolean         @default(false)
  stripeRequirementsJson Json?
  stripeLastSyncedAt   DateTime?
  commissionRate       Decimal?        @db.Decimal(5, 2)
  tags                 StoreTag[]
  media                MediaAsset[]
  items                Item[]
  orders               Order[]
  carts                Cart[]
  posts                Post[]
  bundles              Bundle[]        @relation("StoreBundles")
  teamMembers          TeamMember[]
  invitations          Invitation[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  Promotion            Promotion[]
  FavoriteStore        FavoriteStore[]
  affiliateCommissions Commission[]    @relation("CommissionStore")
  DeliveryJob          DeliveryJob[]
  StoreDeliveryProviderConfigs StoreDeliveryProviderConfig[]
  StoreDeliveryOptions StoreDeliveryOption[]

  @@index([ownerUserId])
  @@index([latitude, longitude]) // For distance queries
  @@index([addressCity, addressState]) // For city search
  @@index([addressZip]) // For zip code search
  @@index([isPublished, latitude]) // For published + location queries
  @@index([referredByAffiliateId])
}

model GeocodingCache {
  id String @id @default(uuid()) @db.Char(36)

  // Query identification
  queryType  String @db.VarChar(20) // 'zip', 'city', 'address'
  queryValue String @db.VarChar(100) // ZIP code, "city,state", full address (truncated for index)

  // Geographic coordinates
  latitude  Decimal @db.Decimal(10, 8) // -90 to 90, 8 decimal precision
  longitude Decimal @db.Decimal(11, 8) // -180 to 180, 8 decimal precision

  // Parsed address components
  city             String?
  state            String? @db.Char(2)
  zip              String?
  country          String? @default("US") @db.Char(2)
  formattedAddress String?

  // Metadata
  confidence String @db.VarChar(10) // 'high', 'medium', 'low'
  source     String @db.VarChar(20) // 'mapbox', 'manual', 'fallback' (legacy rows may say 'positionstack')

  // Cache management
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime? // Optional TTL for cache invalidation

  // Indexes for performance
  @@unique([queryType, queryValue])
  @@index([latitude, longitude])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([queryType])
}

model Item {
  id          String  @id @default(uuid()) @db.Char(36)
  storeId     String  @db.Char(36)
  store       Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title       String
  description String?
  imageUrl   String? @db.VarChar(191) // Item thumbnail
  price       Decimal @db.Decimal(10, 2)
  isActive         Boolean   @default(true)
  isSoldOut        Boolean   @default(false)
  flagged          Boolean   @default(false)
  flaggedAt        DateTime?
  flaggedByAdminId String?   @db.Char(36)
  flaggedReason    String?   @db.Text
  sortIndex        Int       @default(0)
  optionsJson      Json?
  stockQty         Int?

  // Allergen Information
  allergensJson Json? // Array of allergen strings
  spicyLevel    Int? // 0-5 scale

  tags         ItemTag[]
  media        MediaAsset[]
  cartItems    CartItem[]
  orderItems   OrderItem[]
  bundleItems  BundleItem[]   @relation("ItemBundles")
  linkedPosts  Post[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  FavoriteItem FavoriteItem[]

  @@index([storeId, sortIndex])
}

model MediaAsset {
  id        String    @id @default(uuid()) @db.Char(36)
  storeId   String?   @db.Char(36)
  itemId    String?   @db.Char(36)
  bundleId  String?   @db.Char(36)
  store     Store?    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  item      Item?     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  bundle    Bundle?   @relation("BundleMedia", fields: [bundleId], references: [id], onDelete: Cascade)
  kind      MediaKind
  url       String
  altText   String?
  metadata  Json?
  sortIndex Int       @default(0)
  createdAt DateTime  @default(now())

  @@index([storeId])
  @@index([itemId])
  @@index([bundleId])
}

model Cart {
  id        String     @id @default(uuid()) @db.Char(36)
  userId    String     @db.Char(36)
  storeId   String     @db.Char(36)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  status    CartStatus @default(ACTIVE)
  note      String?
  expiresAt DateTime?
  items     CartItem[]
  order     Order?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
  @@index([storeId])
  @@index([expiresAt])
}

model CartItem {
  id            String   @id @default(uuid()) @db.Char(36)
  cartId        String   @db.Char(36)
  cart          Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  itemId        String?  @db.Char(36)
  item          Item?    @relation(fields: [itemId], references: [id], onDelete: Restrict)
  bundleId      String?  @db.Char(36)
  bundle        Bundle?  @relation("BundleCartItems", fields: [bundleId], references: [id], onDelete: Restrict)
  titleSnapshot String
  unitPrice     Decimal  @db.Decimal(10, 2)
  quantity      Int
  optionsJson   Json?
  notes         String?
  createdAt     DateTime @default(now())

  @@index([cartId])
  @@index([itemId])
  @@index([bundleId])
}

model Order {
  id                     String        @id @default(uuid()) @db.Char(36)
  userId                 String        @db.Char(36)
  storeId                String        @db.Char(36)
  cartId                 String?       @unique @db.Char(36)
  user                   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  store                  Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cart                   Cart?         @relation(fields: [cartId], references: [id], onDelete: SetNull)
  /// Affiliate attribution snapshot for vendor analytics (not payout/accounting).
  referredByAffiliateId  String?       @db.Char(36)
  referredByAffiliate    Affiliate?    @relation("AffiliateOrderAttribution", fields: [referredByAffiliateId], references: [id], onDelete: SetNull)
  referredByReferralCode String?
  affiliateAttributionSource AffiliateAttributionSource?
  assignedToUserId       String?       @db.Char(36)
  assignedTo             User?         @relation("OrderAssignedRider", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  /// Initial checkout state; transitions to PLACED after Stripe payment_intent.succeeded. Invariant: status === PLACED ⇒ paymentStatus === PAID (enforced in OrderService + PATCH).
  status                 OrderStatus   @default(PENDING_PAYMENT)
  deliveryType           DeliveryType
  deliveryMode           DeliveryMode   @default(PICKUP)
  paymentStatus          PaymentStatus @default(UNPAID)
  subtotal               Decimal       @db.Decimal(10, 2)
  fees                   Decimal       @db.Decimal(10, 2)
  tax                    Decimal       @db.Decimal(10, 2)
  tip                    Decimal       @db.Decimal(10, 2)
  total                  Decimal       @db.Decimal(10, 2)
  serviceFeePercent      Decimal       @db.Decimal(5, 2)
  serviceFeeAmount       Decimal       @db.Decimal(10, 2)
  netToVendor            Decimal       @db.Decimal(10, 2)
  stripePaymentIntentId  String?       @unique
  stripeChargeId         String?
  stripeTransferId       String?
  stripeApplicationFeeId String?
  stripeRefundId         String?
  addressId              String?       @db.Char(36)
  address                Address?      @relation(fields: [addressId], references: [id], onDelete: SetNull)
  addressSnapshot        Json?

  /// Canonical delivery pin (copied at checkout). Maps / realtime read these — not Address joins.
  deliveryLatitude      Decimal?  @db.Decimal(10, 8)
  deliveryLongitude     Decimal?  @db.Decimal(11, 8)
  deliveryDistanceMiles Decimal?  @db.Decimal(6, 2)
  estimatedDeliveryAt   DateTime?

  // Cancellation & Refund tracking
  cancelReason String?   @db.Text
  canceledBy   String?   @db.Char(36) // User ID who canceled
  canceledAt   DateTime?
  refundReason String?   @db.Text
  refundedAt   DateTime?

  items        OrderItem[]
  events       OrderEvent[]
  tips         Tip[]
  commissions  Commission[]
  payoutOrder  PayoutOrder?
  deliveryJobs DeliveryJob[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId])
  @@index([storeId])
  @@index([paymentStatus])
  @@index([stripeTransferId])
  @@index([status, canceledAt])
  @@index([assignedToUserId])
  @@index([deliveryLatitude, deliveryLongitude])
  @@index([referredByAffiliateId])
}

model DeliveryJob {
  id                 String            @id @default(uuid()) @db.Char(36)
  orderId            String            @db.Char(36)
  storeId            String            @db.Char(36)
  order              Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  store              Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  provider           DeliveryProvider
  status             DeliveryJobStatus @default(REQUESTED)
  providerExternalId String?
  trackingUrl        String?
  providerStatus     String?
  providerPayload    Json?
  requestedByUserId  String?           @db.Char(36)
  requestedBy        User?             @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)
  canceledAt         DateTime?
  completedAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  DeliveryProviderEvents DeliveryProviderEvent[]
  DeliveryTrackingPoints DeliveryTrackingPoint[]

  @@index([orderId])
  @@index([storeId])
  @@index([providerExternalId])
}

model OrderItem {
  id             String  @id @default(uuid()) @db.Char(36)
  orderId        String  @db.Char(36)
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemId         String? @db.Char(36)
  item           Item?   @relation(fields: [itemId], references: [id], onDelete: SetNull)
  bundleId       String? @db.Char(36)
  bundle         Bundle? @relation("BundleOrderItems", fields: [bundleId], references: [id], onDelete: SetNull)
  titleSnapshot  String
  unitPrice      Decimal @db.Decimal(10, 2)
  quantity       Int
  optionsJson    Json?
  notes          String?
  bundleSnapshot Json?

  @@index([orderId])
  @@index([itemId])
}

model OrderEvent {
  id        String      @id @default(uuid()) @db.Char(36)
  orderId   String      @db.Char(36)
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  @@index([orderId, createdAt])
}

model Tip {
  id                     String    @id @default(uuid()) @db.Char(36)
  orderId                String    @db.Char(36)
  order                  Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount                 Decimal   @db.Decimal(10, 2)
  status                 TipStatus @default(PENDING)
  stripePaymentIntentId  String?
  stripeChargeId         String?
  stripeTransferId       String?
  stripeApplicationFeeId String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([orderId])
  @@index([status])
}

model Address {
  id           String    @id @default(uuid()) @db.Char(36)
  userId       String    @db.Char(36)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label        String?
  contactName  String?
  phone        String?
  line1        String
  line2        String?
  city         String
  state        String
  postalCode   String
  country      String
  instructions String?
  /// GeoJSON-like pin: canonical `{ "lat": number, "lng": number }` (see parseGeoJson — latitude/longitude also accepted).
  geo          Json?
  isDefault    Boolean   @default(false)
  isActive     Boolean   @default(true)
  externalRef  String?
  orders       Order[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  archivedAt   DateTime?

  @@index([userId, isActive])
}

model Payout {
  id String @id @default(uuid()) @db.Char(36)

  /// Payouts are typically per vendor (user). Store breakdown lives on PayoutOrder rows.
  vendorUserId String @db.Char(36)
  vendorUser   User   @relation("VendorPayouts", fields: [vendorUserId], references: [id], onDelete: Cascade)

  /// UTC payout period as [periodStart, periodEnd)
  periodStart DateTime
  periodEnd   DateTime

  status PayoutStatus @default(PENDING)

  /// All snapshot math uses integer cents (immutable after COMPLETED).
  grossSalesCents    Int @default(0)
  discountsCents     Int @default(0)
  refundsCents       Int @default(0)
  tipsCents          Int @default(0)
  platformFeesCents  Int @default(0)
  processorFeesCents Int @default(0)
  netPayoutCents     Int @default(0)

  currency String @default("USD") @db.Char(3)

  /// Provider references (optional until automation is implemented)
  providerPayoutId   String?
  providerTransferId String?
  arrivalAt          DateTime?

  /// Audit
  createdByUserId String?   @db.Char(36)
  completedAt     DateTime?
  failedAt        DateTime?
  failureReason   String?   @db.Text

  orders      PayoutOrder[]
  adjustments PayoutAdjustment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorUserId, periodStart, periodEnd])
  @@index([status])
  @@index([providerPayoutId])
}

model PayoutOrder {
  id String @id @default(uuid()) @db.Char(36)

  payoutId String @db.Char(36)
  payout   Payout @relation(fields: [payoutId], references: [id], onDelete: Cascade)

  orderId String @db.Char(36)
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  /// Snapshot fields (integer cents) — do not rely on live joins for completed payouts.
  orderCreatedAt DateTime
  orderStatus    OrderStatus
  paymentStatus  PaymentStatus

  grossSalesCents      Int @default(0)
  discountsCents       Int @default(0)
  refundsCents         Int @default(0)
  tipsCents            Int @default(0)
  platformFeesCents    Int @default(0)
  processorFeesCents   Int @default(0)
  netContributionCents Int @default(0)

  createdAt DateTime @default(now())

  /// Guard: an order must not be included in more than one non-failed payout.
  /// Enforced in service + unique constraint; failed payouts must release orders.
  @@unique([orderId])
  @@index([payoutId])
}

model PayoutAdjustment {
  id String @id @default(uuid()) @db.Char(36)

  payoutId String @db.Char(36)
  payout   Payout @relation(fields: [payoutId], references: [id], onDelete: Cascade)

  type        PayoutAdjustmentType
  amountCents Int
  reason      String
  note        String?              @db.Text

  createdByUserId String?  @db.Char(36)
  createdAt       DateTime @default(now())

  @@index([payoutId])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@unique([key])
}

/// Stripe idempotency: handler loads by eventId, skips if processed=true, else upserts payload, runs handlers, then sets processed=true (see apps/server stripe webhook route).
model PaymentWebhook {
  id        String   @id @default(uuid()) @db.Char(36)
  provider  String   @default("stripe")
  eventId   String   @unique
  type      String
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentMethod {
  id        String          @id @default(uuid()) @db.Char(36)
  userId    String          @db.Char(36)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  PaymentProvider @default(TEST)
  brand     String?
  last4     String?
  tokenRef  String
  isDefault Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId])
}

model Promotion {
  id            String          @id @default(uuid()) @db.Char(36)
  storeId       String?         @db.Char(36)
  store         Store?          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  code          String          @unique
  name          String
  description   String?
  type          PromotionType
  status        PromotionStatus @default(DRAFT)
  value         Decimal         @db.Decimal(10, 2)
  minOrderValue Decimal?        @db.Decimal(10, 2)
  maxDiscount   Decimal?        @db.Decimal(10, 2)
  usageLimit    Int?
  usageCount    Int             @default(0)

  // Enhanced discount features
  usageLimitPerUser Int? // Max uses per customer
  allowStacking     Boolean @default(false)
  eligibleUserIds   Json? // Array of eligible user IDs (for targeted promos)
  excludedUserIds   Json? // Array of excluded user IDs

  validFrom   DateTime
  validUntil  DateTime
  isGlobal    Boolean  @default(false)
  createdById String   @db.Char(36)
  createdBy   User     @relation("PromotionCreator", fields: [createdById], references: [id], onDelete: Cascade)

  redemptions PromotionRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([code])
  @@index([status, validFrom, validUntil])
}

model PromotionRedemption {
  id          String    @id @default(uuid()) @db.Char(36)
  promotionId String    @db.Char(36)
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  userId      String    @db.Char(36)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId     String?   @db.Char(36)

  discountAmount Decimal  @db.Decimal(10, 2)
  redeemedAt     DateTime @default(now())

  @@index([promotionId, userId])
  @@index([userId])
  @@index([orderId])
}

model Post {
  id            String     @id @default(uuid()) @db.Char(36)
  storeId       String     @db.Char(36)
  store         Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  content       String?    @db.Text
  mediaUrls     Json // MediaItem[] - { type, url, thumbnail, title?, provider?, width?, height? }
  likesCount    Int        @default(0)
  commentsCount Int        @default(0)
  sharesCount   Int        @default(0)
  /// Higher sorts first; default 0 for chronological-within-priority
  priority      Int        @default(0)
  /// Presentation key (e.g. default_layout)
  layout        String     @default("default_layout") @db.VarChar(64)
  source        PostSource @default(MANUAL)
  /// Idempotency for automation: e.g. welcome:storeId, item:itemId
  automationKey String?    @unique @db.VarChar(128)
  linkedItemId  String?    @db.Char(36)
  linkedItem    Item?      @relation(fields: [linkedItemId], references: [id], onDelete: SetNull)
  /// If set, post is hidden from public feed / list until this time (UTC). Null = visible immediately.
  publishAt     DateTime?
  likes         PostLike[]
  comments      Comment[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([storeId])
  @@index([createdAt])
  @@index([priority, createdAt, id])
  @@index([publishAt])
}

model PostLike {
  id        String   @id @default(uuid()) @db.Char(36)
  postId    String   @db.Char(36)
  userId    String   @db.Char(36)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId])
}

model Comment {
  id        String   @id @default(uuid()) @db.Char(36)
  postId    String   @db.Char(36)
  userId    String   @db.Char(36)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([userId])
}

// ============================================================================
// AFFILIATE SYSTEM MODELS
// ============================================================================

model AffiliatePayoutGroup {
  id              String      @id @default(uuid()) @db.Char(36)
  name            String
  customerRateBps Int         @default(500)
  storeRateBps    Int         @default(500)
  isDefault       Boolean     @default(false)
  isActive        Boolean     @default(true)
  affiliates      Affiliate[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([isDefault])
  @@index([isActive])
}

model Affiliate {
  id             String          @id @default(uuid()) @db.Char(36)
  userId         String          @unique @db.Char(36)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         AffiliateStatus @default(PENDING)
  referralCode   String          @unique
  referralSlug   String?         @unique @db.VarChar(100)

  /// Kept for Phase 2 backfill — will be dropped after migration validates.
  commissionRate Decimal         @default(0.10) @db.Decimal(5, 4)

  // Phase 1 additions: rate overrides (null = fall through to group → platform default)
  payoutGroupId           String?                  @db.Char(36)
  payoutGroup             AffiliatePayoutGroup?    @relation(fields: [payoutGroupId], references: [id], onDelete: SetNull)
  customerRateBpsOverride Int?
  storeRateBpsOverride    Int?

  // Payout provider
  payoutProvider          AffiliatePayoutProvider  @default(MANUAL)
  payoutProviderAccountId String?
  payoutProviderStatus    AffiliateProviderStatus  @default(NOT_SET)

  // Payout Information
  paypalEmail     String?
  bankAccountJson Json?
  taxId           String?

  // Metadata
  bio     String? @db.Text
  website String?
  // Relationships
  referredStores   Store[]           @relation("AffiliateReferrals")
  referredUsers    User[]            @relation("AffiliateCustomerReferrals")
  attributedOrders Order[]           @relation("AffiliateOrderAttribution")
  commissions      Commission[]
  payouts          AffiliatePayout[]
  referralEvents   ReferralEvent[]
  payoutAuditLogs  PayoutAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referralCode])
  @@index([referralSlug])
  @@index([status])
  @@index([payoutGroupId])
}

model Commission {
  id          String    @id @default(uuid()) @db.Char(36)
  affiliateId String    @db.Char(36)
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  orderId     String    @db.Char(36)
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  storeId     String    @db.Char(36)
  store       Store     @relation("CommissionStore", fields: [storeId], references: [id], onDelete: Cascade)

  // Legacy Decimal fields — kept until Phase 2 backfill validates; will be dropped after.
  amount         Decimal @db.Decimal(10, 2)
  rate           Decimal @db.Decimal(5, 4)
  serviceFeeBase Decimal @db.Decimal(10, 2)

  // Phase 1 additions: integer-cent / bps fields for new commission records
  sourceType            CommissionSourceType?
  commissionBaseCents   Int?
  rateBps               Int?
  amountCents           Int?
  rateSource            AffiliateRateSource?
  payoutGroupIdSnapshot String?              @db.VarChar(36)

  status     CommissionStatus @default(PENDING)
  approvedAt DateTime?
  paidAt     DateTime?

  // Reference to payout batch
  payoutId String?          @db.Char(36)
  payout   AffiliatePayout? @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  auditLogs CommissionAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// MySQL allows multiple NULLs in a unique index, so existing rows (sourceType=NULL)
  /// coexist freely. New rows with a sourceType set are idempotent per (affiliate, order, type).
  @@unique([affiliateId, orderId, sourceType])
  @@index([affiliateId, status])
  @@index([orderId])
  @@index([storeId])
  @@index([payoutId])
  @@index([createdAt])
}

model AffiliatePayout {
  id          String    @id @default(uuid()) @db.Char(36)
  affiliateId String    @db.Char(36)
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  amount Decimal      @db.Decimal(10, 2)
  method String // 'PAYPAL' | 'BANK_TRANSFER' | 'CHECK' | 'STRIPE_TRANSFER'
  status PayoutStatus @default(PENDING)

  // Period covered
  periodStart DateTime
  periodEnd   DateTime

  // Payment details
  referenceId   String? // External reference (PayPal transaction ID, bank reference, etc.)
  failureReason String?
  paidAt        DateTime?

  commissions Commission[]
  auditLogs   PayoutAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([affiliateId, status])
  @@index([status, periodEnd])
}

model PayoutAuditLog {
  id              String            @id @default(uuid()) @db.Char(36)
  affiliateId      String            @db.Char(36)
  affiliatePayoutId String            @db.Char(36)
  affiliate        Affiliate         @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  affiliatePayout AffiliatePayout     @relation(fields: [affiliatePayoutId], references: [id], onDelete: Cascade)
  action          PayoutAuditAction @default(CREATED)
  performedBy     String?           @db.Char(36)
  performedAt     DateTime          @default(now())
  details         Json?
  ipAddress       String?
  createdAt       DateTime          @default(now())

  @@index([affiliateId, performedAt])
  @@index([affiliatePayoutId, action])
  @@index([performedAt])
}

model CommissionAuditLog {
  id              String            @id @default(uuid()) @db.Char(36)
  commissionId    String            @db.Char(36)
  commission      Commission        @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  action          CommissionAuditAction @default(AUTO_APPROVED)
  performedBy     String?           @db.Char(36)
  performedAt     DateTime          @default(now())
  details         Json?
  ipAddress       String?
  createdAt       DateTime          @default(now())

  @@index([commissionId, performedAt])
  @@index([action, performedAt])
  @@index([performedAt])
}

enum PayoutAuditAction {
  CREATED
  APPROVED
  PAID
  REVERSED
  MODIFIED
}

enum CommissionAuditAction {
  AUTO_APPROVED
  AUTO_REVERSED
  MANUAL_APPROVED
  MANUAL_REVERSED
}

model ReferralEvent {
  id              String            @id @default(uuid()) @db.Char(36)
  affiliateId     String            @db.Char(36)
  affiliate       Affiliate         @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  eventType       ReferralEventType
  referredUserId  String?           @db.Char(36)
  referredStoreId String?           @db.Char(36)
  referralCode    String?
  referralSlug    String?
  metadata        Json?
  createdAt       DateTime          @default(now())

  @@index([affiliateId])
  @@index([eventType])
  @@index([createdAt])
}

// ============================================================================
// DELIVERY ZONES
// ============================================================================

model DeliveryZone {
  id      String @id @default(uuid()) @db.Char(36)
  storeId String @db.Char(36)
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name        String
  polygonJson Json // GeoJSON polygon coordinates

  // Fee Structure
  baseFee  Decimal  @db.Decimal(10, 2)
  minOrder Decimal? @db.Decimal(10, 2)

  isActive Boolean @default(true)
  priority Int     @default(0) // Higher priority zones checked first

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, isActive])
  @@index([priority])
}

// ============================================================================
// VENDOR VERIFICATION (KYC/KYB)
// ============================================================================

enum VerificationStatus {
  PENDING
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  REVOKED
}

enum TeamMemberPermission {
  VIEW_ORDERS
  MANAGE_ORDERS
  VIEW_ITEMS
  MANAGE_ITEMS
  VIEW_DELIVERIES
  MANAGE_DELIVERIES
  ASSIGN_DELIVERIES
  VIEW_ANALYTICS
  VIEW_FINANCE
  MANAGE_STORE_SETTINGS
  FULL_ACCESS
}

model VendorVerification {
  id     String @id @default(uuid()) @db.Char(36)
  userId String @unique @db.Char(36)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Business Information
  businessName String
  businessType String // 'INDIVIDUAL' | 'LLC' | 'CORPORATION' | 'PARTNERSHIP'
  taxId        String

  // Documents
  documentsJson Json? // Array of document URLs/IDs

  // Status
  status      VerificationStatus @default(PENDING)
  submittedAt DateTime?
  reviewedAt  DateTime?
  approvedAt  DateTime?
  expiresAt   DateTime?

  // Review notes
  reviewNotes     String? @db.Text
  rejectionReason String? @db.Text

  // Stripe KYC reference
  stripeAccountId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([userId])
}

// ============================================================================
// TEAM MANAGEMENT MODELS
// ============================================================================

model TeamMember {
  id      String @id @default(uuid()) @db.Char(36)
  storeId String @db.Char(36)
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId  String @db.Char(36)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Permissions array stored as JSON
  permissionsJson Json // TeamMemberPermission[]

  isActive  Boolean  @default(true)
  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, userId])
  @@index([userId])
  @@index([storeId, isActive])
}

model Invitation {
  id              String  @id @default(uuid()) @db.Char(36)
  storeId         String  @db.Char(36)
  store           Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  senderUserId    String  @db.Char(36)
  sender          User    @relation("InvitationSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  recipientEmail  String
  recipientUserId String? @db.Char(36)
  recipient       User?   @relation("InvitationRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)

  token           String @unique
  permissionsJson Json // TeamMemberPermission[]

  status  InvitationStatus @default(PENDING)
  message String?          @db.Text

  expiresAt  DateTime
  acceptedAt DateTime?
  declinedAt DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([recipientEmail])
  @@index([token])
  @@index([status, expiresAt])
}

// ============================================================================
// FAVORITES & ENGAGEMENT
// ============================================================================

model FavoriteStore {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    String   @db.Char(36)
  storeId   String   @db.Char(36)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, storeId])
  @@index([userId])
  @@index([storeId])
}

model FavoriteItem {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    String   @db.Char(36)
  itemId    String   @db.Char(36)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, itemId])
  @@index([userId])
  @@index([itemId])
}

// ============================================================================
// BUNDLES & COMBOS
// ============================================================================

model Bundle {
  id          String   @id @default(uuid()) @db.Char(36)
  storeId     String   @db.Char(36)
  store       Store    @relation("StoreBundles", fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  sortIndex   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items      BundleItem[]
  pricing    BundlePricing?
  cartItems  CartItem[]     @relation("BundleCartItems")
  orderItems OrderItem[]    @relation("BundleOrderItems")
  media      MediaAsset[]   @relation("BundleMedia")

  @@index([storeId])
  @@index([isActive])
  @@index([sortIndex])
  @@index([storeId, isActive])
}

model BundleItem {
  id        String @id @default(uuid()) @db.Char(36)
  bundleId  String @db.Char(36)
  bundle    Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  itemId    String @db.Char(36)
  item      Item   @relation("ItemBundles", fields: [itemId], references: [id], onDelete: Cascade)
  quantity  Int    @default(1)
  sortIndex Int    @default(0)

  @@unique([bundleId, itemId])
  @@index([bundleId])
  @@index([itemId])
}

model BundlePricing {
  id       String @id @default(uuid()) @db.Char(36)
  bundleId String @unique @db.Char(36)
  bundle   Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  // Pricing strategy
  pricingType     BundlePricingType @default(FIXED_PRICE)
  fixedPrice      Decimal?          @db.Decimal(10, 2)
  discountPercent Decimal?          @db.Decimal(5, 2) // e.g., 10.00 for 10%
  discountAmount  Decimal?          @db.Decimal(10, 2)

  // Minimum savings guarantee
  minSavings Decimal? @db.Decimal(10, 2)

  // Display settings
  showSavings  Boolean @default(true)
  savingsLabel String? // e.g., "Save $5!"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BundlePricingType {
  FIXED_PRICE // Bundle has a fixed price
  DISCOUNT_PERCENT // Bundle gets X% off total
  DISCOUNT_AMOUNT // Bundle gets $X off total
  BEST_DEAL // Show best available discount
}

// ============================================================================
// SEARCH TAGS (flexible M2M attribute system)
// ============================================================================

model Tag {
  id          String      @id @default(cuid())
  slug        String      @unique
  label       String
  category    TagCategory
  target      TagTarget   @default(BOTH)
  isPublic    Boolean     @default(true)
  sortOrder   Int         @default(0)
  description String?

  stores    StoreTag[]
  items     ItemTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([target])
  @@index([isPublic])
}

model StoreTag {
  storeId String  @db.Char(36)
  tagId   String

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([storeId, tagId])
  @@index([tagId])
  @@index([storeId])
}

model ItemTag {
  itemId String  @db.Char(36)
  tagId  String

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
  @@index([tagId])
  @@index([itemId])
}

model AdminAuditLog {
  id         String   @id @default(uuid()) @db.Char(36)
  adminId    String   @db.Char(36)
  admin      User     @relation("AdminAuditLogs", fields: [adminId], references: [id])
  action     String   @db.VarChar(100)
  targetType String   @db.VarChar(50)
  targetId   String?  @db.VarChar(36)
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
}

// ============================================================================
// DELIVERY PROVIDER CONFIGURATION & TRACKING
// ============================================================================

model StoreDeliveryProviderConfig {
  id          String   @id @default(uuid()) @db.Char(36)
  storeId     String   @db.Char(36)
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  provider    String   // 'IN_HOUSE', 'DOORDASH_DRIVE', 'UBER_DIRECT'
  enabled     Boolean  @default(false)
  settingsJson Json   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storeId, provider])
  @@index([storeId])
  @@index([provider])
  @@index([enabled])
}

model StoreDeliveryOption {
  id               String   @id @default(uuid()) @db.Char(36)
  storeId          String   @db.Char(36)
  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  deliveryMode     String   // 'IN_HOUSE', 'DOORDASH_DRIVE'
  enabled          Boolean  @default(false)
  feeDisclosure    String?  @db.Text
  externalInfoUrl  String?  @db.VarChar(191)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([storeId, deliveryMode])
  @@index([storeId])
  @@index([enabled])
}

model DeliveryProviderEvent {
  id           String   @id @default(uuid()) @db.Char(36)
  deliveryJobId String   @db.Char(36)
  deliveryJob  DeliveryJob @relation(fields: [deliveryJobId], references: [id], onDelete: Cascade)
  provider     String
  eventId      String
  eventType    String
  timestamp    DateTime
  payload      Json
  processed    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([provider, eventId, deliveryJobId])
  @@index([deliveryJobId])
  @@index([provider])
  @@index([processed])
  @@index([timestamp])
  @@index([eventType])
}

model DeliveryTrackingPoint {
  id              String    @id @default(uuid()) @db.Char(36)
  deliveryJobId   String    @db.Char(36)
  deliveryJob     DeliveryJob @relation(fields: [deliveryJobId], references: [id], onDelete: Cascade)
  provider        String
  latitude        Decimal   @db.Decimal(10, 8)
  longitude       Decimal   @db.Decimal(11, 8)
  timestamp       DateTime
  accuracyMeters  Int?
  speedMph        Decimal?  @db.Decimal(5, 2)
  headingDegrees  Int?
  providerPayload Json?
  createdAt       DateTime  @default(now())

  @@index([deliveryJobId])
  @@index([provider])
  @@index([timestamp])
  @@index([latitude, longitude])
}
