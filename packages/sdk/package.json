{
  "name": "@packages/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./realtime": {
      "types": "./dist/src/realtime/index.d.ts",
      "import": "./dist/src/realtime/index.js"
    },
    "./generated/frontend/api/apiWrapper": {
      "types": "./generated/frontend/api/apiWrapper.ts",
      "import": "./generated/frontend/api/apiWrapper.ts"
    },
    "./generated/frontend/api/type-mappers": {
      "types": "./generated/frontend/api/type-mappers.ts",
      "import": "./generated/frontend/api/type-mappers.ts"
    },
    "./generated/frontend/types/backend-types": {
      "types": "./generated/frontend/types/backend-types.ts",
      "import": "./generated/frontend/types/backend-types.ts"
    },
    "./generated/frontend/types/centralized": {
      "types": "./generated/frontend/types/centralized.ts",
      "import": "./generated/frontend/types/centralized.ts"
    },
    "./generated/frontend/hooks/generated": {
      "types": "./generated/frontend/hooks/generated.ts",
      "import": "./generated/frontend/hooks/generated.ts"
    }
  },
  "scripts": {
    "gen": "openapi-generator-cli generate -i ../openapi/openapi.json -g typescript-fetch -o ./generated/sdk --additional-properties=supportsES6=true,importFileExtension=.js,useSingleRequestParameter=true,withoutRuntimeChecks=true",
    "gen:wrapper": "tsx scripts/generate-api-wrapper.ts",
    "gen:types": "tsx scripts/typegen/cli.ts",
    "gen:frontend-types": "tsx scripts/generate-frontend-types.ts",
    "gen:hooks": "tsx scripts/generate-hooks.ts",
    "gen:barrels": "tsx scripts/generate-barrel-exports.ts",
    "gen:all": "npm run gen:wrapper && npm run gen:types && npm run gen:frontend-types && npm run gen:hooks && npm run gen:barrels",
    "gen:unified": "tsx scripts/unified-api-generator.ts",
    "gen:optimized": "tsx scripts/optimized-type-mappers.ts",
    "gen:pipeline": "tsx scripts/api-generation-pipeline.ts",
    "gen:all-client": "tsx scripts/gen-and-validate.ts",
    "gen:all-client:update": "tsx scripts/gen-and-validate.ts --update-snapshots",
    "migrate": "tsx scripts/migrate-to-new-structure.ts",
    "update-imports": "tsx scripts/update-import-paths.ts",
    "validate": "tsx scripts/validate-all.ts",
    "validate:browser": "tsx scripts/validate-browser-compatibility.ts",
    "snapshot": "tsx scripts/snapshot-test.ts",
    "snapshot:update": "tsx scripts/snapshot-test.ts update",
    "build": "tsc -p tsconfig.json",
    "typecheck": "echo 'SDK is generated - skipping typecheck'",
    "lint": "echo 'SDK is generated - skipping lint'",
    "test": "tsx scripts/snapshot-test.ts"
  },
  "dependencies": {
    "@packages/realtime": "workspace:*",
    "@packages/schemas": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.13.4",
    "@types/node": "^20.11.30",
    "eslint": "^9.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}