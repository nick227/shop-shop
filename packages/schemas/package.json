{
  "name": "@packages/schemas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/packages/schemas/src/index.js",
  "types": "./dist/packages/schemas/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/packages/schemas/src/index.js",
      "types": "./dist/packages/schemas/src/index.d.ts",
      "require": "./dist/packages/schemas/src/index.js"
    },
    "./core": {
      "import": "./dist/packages/schemas/src/core/index.js",
      "types": "./dist/packages/schemas/src/core/index.d.ts",
      "require": "./dist/packages/schemas/src/core/index.js"
    },
    "./dtos": {
      "import": "./dist/packages/schemas/src/dtos/index.js",
      "types": "./dist/packages/schemas/src/dtos/index.d.ts",
      "require": "./dist/packages/schemas/src/dtos/index.js"
    }
  },
  "scripts": {
    "gen:dtos": "tsx scripts/generate-dtos-from-prisma.ts",
    "gen:dtos:all": "tsx scripts/generate-all-dtos.ts",
    "gen:openapi": "tsx src/openapi.ts",
    "gen:all": "pnpm gen:dtos:all && pnpm gen:openapi",
    "consolidate:types": "tsx scripts/consolidate-types.ts",
    "consolidate:parallel": "tsx scripts/consolidate-types-parallel.ts",
    "gen:parallel": "tsx scripts/parallel-generator.ts",
    "validate:comprehensive": "tsx scripts/comprehensive-validation.ts",
    "validate:quick": "tsx scripts/quick-validation.ts",
    "validate:simple": "tsx scripts/simple-validation.ts",
    "smoke-test": "tsx scripts/smoke-test.ts",
    "api-smoke-test": "tsx scripts/api-smoke-test.ts",
    "simple-smoke-test": "tsx scripts/simple-smoke-test.ts",
    "working-smoke-test": "tsx scripts/working-smoke-test.ts",
    "build": "pnpm exec tsc && pnpm gen:all",
    "typecheck": "echo 'Schemas imports server code - typecheck at app level'",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "echo 'Schemas package - unit tests coming soon'"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "dotenv": "^17.2.3",
    "eslint": "^9.38.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
