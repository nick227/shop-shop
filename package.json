{
    "name": "delivery-monorepo",
    "private": true,
    "version": "0.1.0",
    "packageManager": "pnpm@9.0.0",
    "scripts": {
        "build": "pnpm -r run build",
        "dev": "pnpm dev:server",
        "dev:server": "pnpm --filter @apps/server dev",
        "dev:web": "pnpm --filter @apps/web dev",
        "db:generate": "pnpm --filter @packages/db generate",
        "db:migrate": "pnpm --filter @packages/db migrate",
        "db:studio": "pnpm --filter @packages/db studio",
        "db:reset": "pnpm --filter @packages/db reset",
        "gen:openapi": "pnpm --filter @packages/schemas gen:openapi",
        "gen:sdk": "pnpm --filter @packages/sdk gen",
        "gen:client": "pnpm --filter @packages/sdk gen:all-client",
        "gen:all": "pnpm db:generate && pnpm gen:openapi && pnpm gen:sdk",
        "gen:full": "pnpm gen:all && pnpm gen:client",
        "fresh": "pnpm db:reset && pnpm db:migrate && pnpm gen:all",
        "bootstrap": "echo Remember to: 1) Copy .env.example to .env  2) Edit DATABASE_URL  3) Run pnpm fresh",
        "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm madge",
        "check:fast": "pnpm lint && pnpm test",
        "lint": "pnpm -r run lint",
        "lint:fix": "pnpm -r exec eslint . --ext .ts --fix || true",
        "typecheck": "pnpm -r run typecheck",
        "knip": "knip",
        "madge": "madge --extensions ts,tsx --circular apps packages",
        "test": "pnpm -r run test",
        "test:watch": "pnpm --filter @apps/server test:watch",
        "e2e": "pnpm --filter @apps/web test:e2e",
        "clean": "pnpm -r exec rm -rf dist node_modules .turbo",
        "setup": "pnpm install && pnpm db:generate",
        "validate": "tsx scripts/validate-packages.ts",
        "pre-dev": "tsx scripts/pre-dev.ts",
        "regenerate": "tsx scripts/regenerate-all.ts",
        "test:integration": "tsx scripts/test-frontend-integration.ts",
        "validate:full": "tsx scripts/full-validation.ts"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "devDependencies": {
        "@vitest/coverage-v8": "^2.1.1",
        "eslint": "^9.9.0",
        "knip": "^5.27.0",
        "madge": "^8.0.0",
        "prettier": "^3.3.3",
        "tsx": "^4.20.6",
        "typescript": "^5.6.2"
    }
}
