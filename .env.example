# Database
DATABASE_URL=mysql://user:password@localhost:3306/delivery_app

# Server
PORT=3005
APP_URL=http://localhost:3005
NODE_ENV=development

# JWT Secrets (generate your own for production)
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_at_least_32_characters_long
JWT_EXPIRES_IN=7d

# Redis for sessions (optional for local development)
REDIS_URL=redis://localhost:6379

# CORS - Frontend URL
CORS_ORIGINS=http://localhost:5177
WEB_PORT=5177

# Frontend: for `pnpm dev` in apps/web, leave VITE_API_URL unset or empty so requests stay on the
# Vite origin and `vite.config.ts` proxies /api → the API (no CORS). Use explicit URLs when not
# using the Vite dev server (e.g. E2E on fixed ports, or preview against a remote API).
# VITE_API_URL=http://localhost:3005
VITE_WS_URL=ws://localhost:3005/realtime

# Stripe (required for production)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Storage
STORAGE_TYPE=local
UPLOAD_DIR=./uploads

# Geocoding (optional)
GEOCODING_API_KEY=your_geocoding_api_key

# Error Reporting (optional)
ERROR_ENDPOINT=your_error_reporting_endpoint

# Application URL
APP_URL=http://localhost:3005

# DoorDash Drive webhooks — use HTTPS in staging/production.
# Public Drive docs: protect endpoints with Basic Auth or OAuth (signing headers are tenant-specific).
# When NODE_ENV=production, DOORDASH_WEBHOOK_AUTH_MODE must be "basic" or "hmac" (never omitted / none).

# Local: open webhook (dev only)
# DOORDASH_WEBHOOK_AUTH_MODE=none

# Local / staging: Basic Auth
# DOORDASH_WEBHOOK_AUTH_MODE=basic
# DOORDASH_WEBHOOK_BASIC_USER=shopshop
# DOORDASH_WEBHOOK_BASIC_PASSWORD=local-secret

# If DoorDash (or your gateway) gives you HMAC over the raw JSON body:
# DOORDASH_WEBHOOK_AUTH_MODE=hmac
# DOORDASH_WEBHOOK_SECRET=
# DOORDASH_WEBHOOK_SIGNATURE_HEADER=x-doordash-signature

DOORDASH_WEBHOOK_AUTH_MODE=none
DOORDASH_WEBHOOK_BASIC_USER=
DOORDASH_WEBHOOK_BASIC_PASSWORD=
DOORDASH_WEBHOOK_SECRET=
DOORDASH_WEBHOOK_SIGNATURE_HEADER=x-doordash-signature