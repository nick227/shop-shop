{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "@packages/db": ["./packages/db/src"],
      "@packages/db/*": ["./packages/db/src/*"],
      "@packages/domain": ["./packages/domain/src"],
      "@packages/domain/*": ["./packages/domain/src/*"],
      "@packages/schemas": ["./packages/schemas/src"],
      "@packages/schemas/*": ["./packages/schemas/src/*"],
      "@packages/schemas-river-dto": ["./packages/schemas/src/dtos/river.dto.ts"],
      "@packages/sdk": ["./packages/sdk/src"],
      "@packages/sdk/*": ["./packages/sdk/src/*"],
      "@packages/shared": ["./packages/shared/src"],
      "@packages/shared/*": ["./packages/shared/src/*"],
      "@packages/realtime": ["./packages/realtime/src"],
      "@packages/realtime/*": ["./packages/realtime/src/*"]
    }
  }
}