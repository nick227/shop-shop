# npm does not recognize pnpm-only keys (e.g. confirm-modules-purge); use:
#   pnpm config set confirm-modules-purge false --location user
# if you want to skip the "reinstall node_modules from scratch?" prompt in CI/agents.

# Avoid interactive "reinstall node_modules from scratch?" during pnpm install (CI/agents).
confirm-modules-purge=false
